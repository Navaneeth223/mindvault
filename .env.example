# ─── Django Core ───────────────────────────────────────────────────────────────
SECRET_KEY=your-very-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ─── Database ──────────────────────────────────────────────────────────────────
# SQLite (default dev): leave blank or set to sqlite:///db.sqlite3
# PostgreSQL (production): postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://mindvault:mindvault_password@db:5432/mindvault

# ─── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ─── Media / Storage ───────────────────────────────────────────────────────────
MEDIA_ROOT=/app/media
MEDIA_URL=/media/

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Access token lifetime in minutes
JWT_ACCESS_TOKEN_LIFETIME=15
# Refresh token lifetime in days
JWT_REFRESH_TOKEN_LIFETIME=30

# ─── Whisper (Speech-to-Text) ──────────────────────────────────────────────────
# Options: tiny, base, small, medium, large
# Use 'tiny' or 'base' on low-resource machines
WHISPER_MODEL=base

# ─── GitHub API ────────────────────────────────────────────────────────────────
# Optional: increases rate limit from 60 to 5000 req/hour
GITHUB_TOKEN=

# ─── Email (optional, for future notifications) ────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ─── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=MindVault
VITE_APP_VERSION=1.0.0
